# ─── Turso (requerido en Vercel) ─────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=

# ─── Local / Render (archivos SQLite; se ignoran si hay TURSO_*) ──────────────
# SQLITE_PATH=./data/alturas.sqlite
# PARAGUAY_SQLITE_PATH=./data/paraguay_dmh.sqlite
# PASOS_SQLITE_PATH=./data/pasos.sqlite

NODE_ENV=production
TRUST_PROXY=1
CACHE_TTL_MS=600000

# Cron de Vercel (Authorization: Bearer …) — sync diario a Turso
CRON_SECRET=
